{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts", "**/*.d.ts", "**/*.js", "**/*.mjs", "**/*.cjs"],
  "exclude": ["node_modules", "**/node_modules", "**/_archive", "dist", "build", ".azure", "coverage"]
}
