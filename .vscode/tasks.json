{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Install Dependencies",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder:ROOT}"
      }
    },
    {
      "label": "Start azurite",
      "type": "shell",
      "command": "pnpm",
      "args": ["exec", "azurite", "--silent", "--location", "${workspaceFolder:ROOT}/azurite", "--debug", "${workspaceFolder:ROOT}/azurite/debug.log"],
      "isBackground": true,
      "dependsOn": ["Install Dependencies"],
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Azurite Blob service is successfully listening"
        }
      }
    },
    {
      "type": "func",
      "label": "func: host start",
      "command": "host start",
      "problemMatcher": "$func-node-watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/module\\quest3Tier\\func"
      }
    }
  ]
}
